CONST/POINT,F(ROUGH_DATUM_B_HIGH_POINT),EXTREM,MIN,FA(ROUGH_DATUM_B_PLANE),YDIR
 
D(RA)=DATSET/DAT(ROUGH_A),-XDIR,XORIG
 
DECL/LOCAL,DOUBLE,YOPOINT,YOTAN
 
YOTAN=ASSIGN/TAN(DTOR(5))
 
YOPOINT=OBTAIN/FA(ROUGH_DATUM_B_HIGH_POINT),3
YOPOINT=ASSIGN/YOPOINT*YOTAN
 
F(ROUGH_B_FUNCTIONAL_POINT)=FEAT/POINT,CART,0.0298858,0,-2.31,0,1,0
CONST/POINT,F(ROUGH_B_FUNCTIONAL_POINT),MOVEPT,FA(ROUGH_DATUM_B_HIGH_POINT),0,YOPOINT,0
 
DATDEF/FA(ROUGH_DATUM_A_PLANE), DAT(ROUGH_A)
